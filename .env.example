# ── LLM (required) ───────────────────────────────────────────────────────────
# Local llama-server / vLLM:
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=bartowski/Qwen_Qwen3-14B-GGUF:Q4_K_M

# Cloud vLLM via Jupyter server proxy (e.g. AMD MI300X):
# LLM_BASE_URL=https://<jupyter-host>/proxy/8000/v1
# LLM_MODEL=Qwen/Qwen3-32B
# JUPYTER_TOKEN=<your-jupyter-server-token>

# ── News search (optional) ────────────────────────────────────────────────────
# SerpAPI key — enables live Google News. Falls back to synthetic data if unset.
# SERP_API_KEY=

# ── LangSmith observability (optional) ───────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=brand-risk

# ── Slack alerts (optional) ───────────────────────────────────────────────────
# Incoming webhook URL from your Slack app. Silent no-op if unset.
# SLACK_WEBHOOK_URL=

# ── Email alerts (optional) ───────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password-here
# ALERT_EMAIL_TO=cro@yourcompany.com

# ── Reddit connector (optional) ───────────────────────────────────────────────
# Requires praw>=7.8.2 installed. See requirements.txt.
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often the headless scheduler runs (minutes). Default: 15.
# MONITOR_INTERVAL=15

# ── Storage paths (optional) ─────────────────────────────────────────────────
# BRAND_RISK_DB=brand_risk.db
# CHROMA_DIR=.chroma

# ── Embeddings (optional) ─────────────────────────────────────────────────────
# EMBED_MODEL=BAAI/bge-small-en-v1.5
